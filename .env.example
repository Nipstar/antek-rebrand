VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

VITE_CONTACT_WEBHOOK_URL=https://your-n8n-instance.com/webhook/contact
VITE_CHATBOT_WEBHOOK_URL=https://your-n8n-instance.com/webhook/chatbot

# Google reCAPTCHA v2 ("I'm not a robot" challenge) — protects the contact form.
# Site key is public (shipped to the browser); secret key stays server-side.
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v2_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_v2_secret_key
# Server-side n8n webhook used by the /api/contact serverless function.
# No VITE_ prefix => never exposed to the browser. Set this in Vercel.
CONTACT_WEBHOOK_URL=https://your-n8n-instance.com/webhook/contact

# Server-side WF9 webhook used by the /api/visibility-check serverless function
# (the Free AI Visibility Check form). Falls back to CONTACT_WEBHOOK_URL until WF9
# is live. No VITE_ prefix => never exposed to the browser. Set this in Vercel.
VISIBILITY_WEBHOOK_URL=https://your-n8n-instance.com/webhook/visibility-check

VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_CLARITY_ID=your_clarity_project_id
